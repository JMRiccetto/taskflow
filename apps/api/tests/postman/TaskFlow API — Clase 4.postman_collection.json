                "exec": [
                  "pm.test('Status 201 Created', () => {",
                  " pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response tiene id y email', () => {",
                  " const body = pm.response.json();",
                  " pm.expect(body.user).to.have.property('id');",
                  " pm.expect(body.user.email).to.eql('ana@ejemplo.com');",
                  "});"
