                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Ana García\",\n    \"email\": \"ana@ejemplo.com\",\n    \"password\": \"Segura123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
