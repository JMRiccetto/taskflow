{
  "name": "@taskflow/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "test": "dotenv -e .env.test --override -- vitest run",
    "test:unit": "dotenv -e .env.test --override -- vitest run tests/unit --coverage",
    "test:integration": "dotenv -e .env.test --override -- vitest run tests/integration",
    "test:bdd": "dotenv -e .env.test --override -- cucumber-js",
    "test:watch": "dotenv -e .env.test --override -- vitest",
    "db:migrate:test": "dotenv -e .env.test --override -- prisma migrate deploy --schema=src/prisma/schema.prisma",
    "postinstall": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma": "prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "tsx src/prisma/seed.ts"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.8.0",
    "@pact-foundation/pact": "^16.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^1.6.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.4.0",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "tsx": "^4.11.2",
    "vitest": "^1.6.0"
  }
}
